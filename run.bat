@echo off
title تشغيل منظومة المبيعات والمخزون
chcp 65001 > nul
color 0a

echo ==========================================================
echo        منظومة مستلزمات المقاهي والمطاعم (RTL POS)
echo ==========================================================
echo.
echo  [+] جاري تشغيل خوادم المنظومة وقاعدة البيانات...
