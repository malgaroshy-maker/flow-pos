@echo off
title منظومة مستلزمات المقاهي والمطاعم — Flow POS
chcp 65001 > nul
color 0A

echo ======================================================================
echo           منظومة Flow — إدارة المبيعات والمخزون والخزينة
echo                      نسخة محلية تعمل بدون إنترنت
echo ======================================================================
echo.

:: التحقق من وجود Node.js
where node >nul 2>&1
if %errorlevel% neq 0 (
    color 0C
    echo [خطأ] لم يتم العثور على Node.js على هذا الجهاز!
    echo يرجى تثبيت Node.js أولاً ثم إعادة تشغيل المنظومة.
    echo.
    pause
    exit /b 1
)

:: التحقق من التبعيات node_modules
if not exist "node_modules\" (
    echo [*] جاري تثبيت حزم المنظومة لأول مرة، يرجى الانتظار...
    call npm install
    if %errorlevel% neq 0 (
        color 0C
        echo [خطأ] فشل تثبيت الحزم. يرجى التحقق وإعادة المحاولة.
        pause
        exit /b 1
    )
)

echo  [+] الخادم محلي وجاهز للعمل.
echo  [+] فتح المنظومة في المتصفح تلقائياً خلال ثوانٍ...
echo  [+] للوصول من أجهزة الكاشير عبر الشبكة المحلية (WiFi):
echo      افتح المتصفح على عنوان الآي بي الخاص بهذا الحاسوب: Port 5173
echo.
echo ======================================================================
echo  [!] لإيقاف تشغيل الخادم، أغلق هذه النافذة أو اضغط (Ctrl + C)
echo ======================================================================
echo.

:: فتح المتصفح في الخلفية بعد تشغيل الخادم بـ 4 ثوانٍ
start /b cmd /c "timeout /t 4 /nobreak >nul && start http://localhost:5173"

:: بدء تشغيل خوادم التطبيق (الخادم والواجهة)
npm run dev
