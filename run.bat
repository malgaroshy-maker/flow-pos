echo  [+] لإيقاف المنظومة، قم بإغلاق هذه النافذة أو اضغط Ctrl + C.
echo.
echo ==========================================================
echo.

:: فتح رابط المنظومة في المتصفح الافتراضي تلقائياً بعد 3 ثوانٍ
timeout /t 3 /nobreak > nul
start "" "http://localhost:5173"

:: تشغيل التطبيق بالكامل
npm run dev
