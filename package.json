{
  "name": "pos",
  "private": true,
  "version": "0.1.0",
  "description": "نظام المبيعات والمخزون — offline-first POS for café/restaurant supplies",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "build": "npm run build -w server && npm run build -w web",
    "test": "npm run test -w server",
    "test:e2e": "playwright test",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w web",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,md,json}\"",
    "db:generate": "npm run db:generate -w server",
    "db:migrate": "npm run db:migrate -w server",
    "db:seed": "npm run db:seed -w server"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "docx": "^9.7.1",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.5.3"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    },
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  }
}
